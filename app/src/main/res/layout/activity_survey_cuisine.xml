<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F2EF">

    <!-- SCROLL CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="26dp"
            android:paddingTop="34dp"
            android:paddingBottom="10dp">

            <!-- TOP -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/img_food_logo"/>

                <ProgressBar
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:max="100"
                    android:progress="35"
                    android:progressTint="#F2C129"
                    android:progressBackgroundTint="#ECECEC"/>

            </LinearLayout>

            <!-- QUESTION BOX -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginTop="34dp"
                android:background="@drawable/bg_survey_option"
                android:gravity="center"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="What cuisines do you enjoy?"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#222222"
                    android:gravity="center"/>

            </LinearLayout>

            <!-- OPTIONS -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="22dp">

                <!-- SELECTED -->

                <TextView
                    android:id="@+id/optionVietnamese"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="Vietnamese"
                    android:textColor="#222222"
                    android:textSize="17sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="18dp"
                    android:background="@drawable/bg_input"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/optionAmerican"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="American"
                    android:textColor="#222222"
                    android:textSize="17sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="18dp"
                    android:background="@drawable/bg_input"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/optionItalian"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="Italian"
                    android:textColor="#222222"
                    android:textSize="17sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="18dp"
                    android:background="@drawable/bg_input"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/optionThai"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="Thai"
                    android:textColor="#222222"
                    android:textSize="17sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="18dp"
                    android:background="@drawable/bg_input"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/optionKorean"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="Korean"
                    android:textColor="#222222"
                    android:textSize="17sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="18dp"
                    android:background="@drawable/bg_input"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/optionChinese"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="Chinese"
                    android:textColor="#222222"
                    android:textSize="17sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="18dp"
                    android:background="@drawable/bg_input"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- FIXED NEXT BUTTON -->
    <Button
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="26dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="26dp"
        android:text="Next"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_button_green"/>

</LinearLayout>