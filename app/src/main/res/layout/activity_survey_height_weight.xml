<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#8ED16F"
    android:padding="20dp">

    <!-- Progress -->
    <ProgressBar
        android:layout_width="match_parent"
        android:layout_height="8dp"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_marginTop="50dp"
        android:layout_marginBottom="10dp"
        android:progress="100"
        android:progressTint="#F4C542"
        android:backgroundTint="#E0E0E0" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/img_food_logo"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What is your height/weight?"
            android:layout_marginStart="12dp"
            android:padding="12dp"
            android:background="@drawable/bg_input"/>
    </LinearLayout>

    <!-- HEIGHT -->
    <TextView
        android:id="@+id/txtHeight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="170 Cm"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="50dp"/>

    <com.example.mealrecommendationapp.ui.custom.RulerView
        android:id="@+id/rulerHeight"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="40dp"/>

    <!-- WEIGHT -->
    <TextView
        android:id="@+id/txtWeight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="60 Kg"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="40dp"/>

    <com.example.mealrecommendationapp.ui.custom.RulerView
        android:id="@+id/rulerWeight"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="20dp"/>

    <!-- Spacer đẩy nút xuống -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Button -->
    <Button
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Next"
        android:background="@drawable/bg_button_yellow"
        android:textColor="#FFFFFF"/>

</LinearLayout>