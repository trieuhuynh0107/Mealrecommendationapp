<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F2EF"
    android:orientation="vertical">

    <!-- CONTENT -->

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">
            <!-- TOP BAR -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnMenu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☰"
                    android:textSize="28sp"
                    android:textColor="#222222"/>

            </LinearLayout>

            <!-- TITLE -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calories"
                android:textColor="#222222"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginTop="18dp"/>

            <!-- CALORIES CARD -->

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F3E39B">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <!-- ARC -->

                    <FrameLayout
                        android:layout_width="220dp"
                        android:layout_height="150dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="16dp">

                        <com.example.mealrecommendationapp.ui.custom.CaloriesArcView
                            android:id="@+id/caloriesArc"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"/>

                        <!-- CENTER TEXT -->

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtCalories"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1721 Kcal"
                                android:textSize="30sp"
                                android:textStyle="bold"
                                android:textColor="#222222"/>

                            <TextView
                                android:id="@+id/txtGoal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="of 2213 kcal"
                                android:textColor="#999999"/>

                        </LinearLayout>

                    </FrameLayout>

                    <!-- MACROS -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="20dp"
                        android:orientation="horizontal">


                        <!-- PROTEIN -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Protein"
                                android:textStyle="bold"/>

                            <ProgressBar
                                android:id="@+id/proteinProgress"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="70dp"
                                android:layout_height="6dp"
                                android:max="100"
                                android:progress="0"
                                android:progressTint="#73D67A"
                                android:progressBackgroundTint="#DDDDDD"/>

                            <TextView
                                android:id="@+id/txtProtein"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0/0g"
                                android:textSize="12sp"/>

                        </LinearLayout>

                        <!-- FATS -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fats"
                                android:textStyle="bold"/>

                            <ProgressBar
                                android:id="@+id/fatsProgress"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="70dp"
                                android:layout_height="6dp"
                                android:max="100"
                                android:progress="0"
                                android:progressTint="#FF8E6D"
                                android:progressBackgroundTint="#DDDDDD"/>

                            <TextView
                                android:id="@+id/txtFats"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0/0g"
                                android:textSize="12sp"/>

                        </LinearLayout>

                        <!-- CARBS -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Carbs"
                                android:textStyle="bold"/>

                            <ProgressBar
                                android:id="@+id/carbsProgress"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="70dp"
                                android:layout_height="6dp"
                                android:max="100"
                                android:progress="0"
                                android:progressTint="#E4C047"
                                android:progressBackgroundTint="#DDDDDD"/>

                            <TextView
                                android:id="@+id/txtCarbs"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0/0g"
                                android:textSize="12sp"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- FOOD LIST -->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerFood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM NAV -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#FFFFFF"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⌂"
            android:textSize="20sp"/>


        <!-- CENTER BUTTON -->

        <ImageView
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:padding="12dp"
            android:src="@drawable/img_food_logo"
            android:scaleType="centerInside"/>

        <TextView
            android:id="@+id/btnCalendar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="▦"
            android:textSize="20sp"
            android:textColor="#1F2A44"/>


    </LinearLayout>

</LinearLayout>